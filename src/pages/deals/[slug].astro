---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContactForm from "../../components/ContactForm.astro";
import { deals } from "../../data/deals";

export const prerender = true;

export function getStaticPaths() {
  return deals.map((deal) => ({ params: { slug: deal.slug }, props: { deal } }));
}

const { deal } = Astro.props;
---

<BaseLayout title={deal.name} description={deal.summary} image={deal.featuredImage}>
  <article class="article deal-article">
    <p class="eyebrow">{deal.category}</p>
    <h1>{deal.name}</h1>
    <p class="lead">{deal.summary}</p>
    <figure class="featured-image">
      <img src={deal.featuredImage} alt={`${deal.name} featured visual`} />
    </figure>
    <p>{deal.details}</p>
    <div class="actions">
      <a class="button" href={deal.href} target="_blank" rel="noreferrer">Claim</a>
      <a class="button secondary" href="/deals/">All deals</a>
    </div>
  </article>
  <section class="contact-panel">
    <div>
      <p class="eyebrow">Partner Access</p>
      <h2>Need a warm route?</h2>
      <p>For partner-led deals, use the form and include your company context.</p>
    </div>
    <ContactForm />
  </section>
</BaseLayout>
