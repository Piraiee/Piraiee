---
import {
  getCalCookieName,
  isValidCalSession
} from "../lib/calAuth";
import "@fontsource/inter/400.css";
import "@fontsource/inter/600.css";
import "@fontsource/inter/700.css";
import "@fontsource/manrope/600.css";
import "@fontsource/manrope/700.css";
import "../styles/global.css";

export const prerender = false;

const env = Astro.locals.runtime?.env ?? {};
const session = Astro.cookies.get(getCalCookieName())?.value;
const isUnlocked = await isValidCalSession(session, env.CAL_AUTH_SECRET || "");
const error = Astro.url.searchParams.get("error");
const errorMessage = error === "invalid"
  ? "That password is not correct. Please try again."
  : error === "setup"
    ? "Private scheduling is not configured yet."
    : error === "delivery"
      ? "Access could not be confirmed right now. Please try again shortly."
    : "";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Private scheduling | Ahmad Piraiee</title>
    <meta name="description" content="Private meeting scheduling with Ahmad Piraiee." />
    <meta name="robots" content="noindex, nofollow, noarchive" />
    <meta name="referrer" content="no-referrer" />
    <link rel="icon" type="image/png" href="/favicon.png" />
  </head>
  <body class="cal-page">
    {isUnlocked ? (
      <main class="cal-shell" id="main">
        <header class="cal-header">
          <div>
            <p class="cal-kicker">Private scheduling</p>
            <h1>Find a time that works.</h1>
          </div>
          <a class="cal-back-home" href="/">
            <span aria-hidden="true">←</span>
            <span>Back to home</span>
          </a>
        </header>
        <p class="cal-intro">Choose a 30-minute or one-hour meeting. Availability is shown in your timezone.</p>
        <section class="cal-embed-frame" aria-label="Meeting availability">
          <div id="cal-inline" class="cal-embed"></div>
          <noscript>
            <p class="cal-noscript">JavaScript is required to view availability. <a href="https://cal.id/piraiee/1-1">Open scheduling</a>.</p>
          </noscript>
        </section>
      </main>
    ) : (
      <main class="cal-lock-shell" id="main">
        <section class="cal-lock-panel" aria-labelledby="cal-lock-title">
          <p class="cal-kicker">Private scheduling</p>
          <h1 id="cal-lock-title">Schedule a meeting.</h1>
          <p>Use your private access code to view my live availability and book a time that works for both of us.</p>
          <form action="/api/cal-auth" method="post" class="cal-lock-form">
            <label for="cal-password">Access code</label>
            <div class="cal-password-field">
              <div class="cal-password-input">
                <input id="cal-password" name="password" type="password" autocomplete="current-password" required autofocus aria-describedby={errorMessage ? "cal-error" : undefined} />
                <button class="cal-password-toggle" type="button" aria-label="Show access code" aria-pressed="false" title="Show access code">
                  <svg class="cal-eye-show" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M2.5 12s3.5-6 9.5-6 9.5 6 9.5 6-3.5 6-9.5 6-9.5-6-9.5-6Z" />
                    <circle cx="12" cy="12" r="2.75" />
                  </svg>
                  <svg class="cal-eye-hide" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 3l18 18" />
                    <path d="M10.6 6.15A10.7 10.7 0 0 1 12 6c6 0 9.5 6 9.5 6a16.7 16.7 0 0 1-2.2 2.85M6.1 6.1C3.75 7.75 2.5 12 2.5 12s3.5 6 9.5 6a9.7 9.7 0 0 0 3.05-.48" />
                  </svg>
                </button>
              </div>
              <button class="cal-submit" type="submit">Continue <span aria-hidden="true">↗</span></button>
            </div>
            {errorMessage && <p class="cal-error" id="cal-error" role="alert">{errorMessage}</p>}
          </form>
        </section>
      </main>
    )}

    {isUnlocked && (
      <script is:inline>
        (function (C, A, L) {
          const p = function (a, ar) { a.q.push(ar); };
          const d = C.document;
          C.Cal = C.Cal || function () {
            const cal = C.Cal;
            const ar = arguments;
            if (!cal.loaded) {
              cal.ns = {};
              cal.q = cal.q || [];
              const script = d.createElement("script");
              script.src = A;
              d.head.appendChild(script);
              cal.loaded = true;
            }
            if (ar[0] === L) {
              const api = function () { p(api, arguments); };
              const namespace = ar[1];
              api.q = api.q || [];
              if (typeof namespace === "string") {
                cal.ns[namespace] = cal.ns[namespace] || api;
                p(cal.ns[namespace], ar);
                p(cal, ["initNamespace", namespace]);
              } else p(cal, ar);
              return;
            }
            p(cal, ar);
          };
        })(window, "https://app.cal.com/embed/embed.js", "init");

        Cal("init", "private-scheduling", { origin: "https://cal.id" });
        Cal.ns["private-scheduling"]("inline", {
          elementOrSelector: "#cal-inline",
          calLink: "piraiee/1-1",
          config: { layout: "week_view" }
        });
        Cal.ns["private-scheduling"]("ui", {
          styles: {
            branding: { brandColor: "#0b1020" },
            body: { background: "transparent" }
          },
          hideEventTypeDetails: false,
          layout: "week_view"
        });
        Cal.ns["private-scheduling"]("on", {
          action: "bookingSuccessfulV2",
          callback: function () {
            window.location.assign("https://piraiee.com/");
          }
        });

        // Cal.com calculates an inline iframe height for the current layout but
        // does not reliably shrink it after crossing its mobile breakpoint.
        window.matchMedia("(max-width: 1024px)").addEventListener("change", function () {
          window.location.reload();
        });
      </script>
    )}
    {!isUnlocked && (
      <script is:inline>
        const passwordInput = document.querySelector("#cal-password");
        const passwordToggle = document.querySelector(".cal-password-toggle");

        passwordToggle?.addEventListener("click", () => {
          if (!(passwordInput instanceof HTMLInputElement) || !(passwordToggle instanceof HTMLButtonElement)) return;
          const willShow = passwordInput.type === "password";
          passwordInput.type = willShow ? "text" : "password";
          passwordToggle.setAttribute("aria-pressed", String(willShow));
          passwordToggle.setAttribute("aria-label", willShow ? "Hide access code" : "Show access code");
          passwordToggle.title = willShow ? "Hide access code" : "Show access code";
          passwordInput.focus({ preventScroll: true });
        });
      </script>
    )}
  </body>
</html>
