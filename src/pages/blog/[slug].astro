---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { posts } from "../../data/posts";

export const prerender = true;

export function getStaticPaths() {
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
---

<BaseLayout title={post.title} description={post.excerpt}>
  <article class="article">
    <p class="eyebrow">{post.category}</p>
    <h1>{post.title}</h1>
    <time datetime={post.date}>{new Date(post.date).toLocaleDateString("en", { month: "long", day: "numeric", year: "numeric" })}</time>
    <p class="lead">{post.excerpt}</p>
    <p>
      This imported entry is staged as a concise SEO-ready article shell. The full editorial copy can
      be expanded from the Squarespace archive, rewritten with a sharper point of view, or replaced
      with fresh analysis before launch.
    </p>
    <p>
      The important part is structural: every post has a clean canonical URL, title, description,
      category, date, and internal linking path.
    </p>
  </article>
</BaseLayout>
