---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleShare from "../../components/ArticleShare.astro";
import { posts } from "../../data/posts";

export const prerender = true;

export function getStaticPaths() {
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;

const formatDate = (date: string) => {
  const value = new Date(date + "T00:00:00");
  return value
    .toLocaleDateString("en-GB", { day: "2-digit", month: "short", year: "numeric" })
    .toUpperCase();
};

const stripHtml = (value: string) => value.replace(/<[^>]+>/g, "").replace(/&amp;/g, "&").trim();
const isLegacyTagLine = (html: string) => {
  const text = stripHtml(html).replace(/^Tags:\s*/i, "");
  return text.length > 1 && text.length < 110 && !/[.!?]$/.test(text) && /,|\|/.test(text);
};
const cleanContent = (value: string) => {
  let cleaned = value.replace(
    /<div>\s*<h4>\s*<strong>\s*Subscribe to Startup Digest to stay ahead with the latest news, investments, and must-attend events\.\s*<\/strong>\s*<\/h4>\s*<\/div>/gi,
    ""
  );
  cleaned = cleaned.replace(/<p>([\s\S]*?)<\/p>/gi, (match, content) =>
    isLegacyTagLine(content) ? "" : match
  );
  return cleaned;
};

const articleContent = cleanContent(post.content);
---

<BaseLayout
  title={post.title}
  description={post.excerpt}
  image={post.featuredImage}
  imageAlt={`${post.title} — featured image`}
  schemaType="BlogPosting"
  publishedTime={`${post.date}T00:00:00+02:00`}
  section={post.category}
>
  <article class="article">
    <a class="eyebrow article-category" href={`/blog/?category=${encodeURIComponent(post.category)}`}>{post.category}</a>
    <h1>{post.title}</h1>
    <time datetime={post.date}>{formatDate(post.date)}</time>
    <p class="lead">{post.excerpt}</p>
    <figure class="featured-image">
      <img src={post.featuredImage} alt={`${post.title} featured visual`} />
    </figure>
    <ArticleShare title={post.title} slug={post.slug} />
    <div class="article-content" set:html={articleContent} />
  </article>
</BaseLayout>
