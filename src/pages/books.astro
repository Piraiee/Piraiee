---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Books" description="Books, reading notes, and ideas that shape Ahmad Piraiee's work.">
  <section class="page-hero compact">
    <p class="eyebrow">Books</p>
    <h1>Reading for builders, strategists, and curious operators.</h1>
  </section>
  <section class="content-section">
    <p>
      This section is ready for curated books, reading lists, and notes. It can be powered by simple
      Markdown files so new recommendations are easy to publish without a CMS bill.
    </p>
  </section>
</BaseLayout>
