---
import BaseLayout from "../layouts/BaseLayout.astro";
import BackToTop from "../components/BackToTop.astro";
import { books } from "../data/books";
import { seo } from "../data/seo";

const publicationYear = (value: string) => {
  if (value === "n.d.") return value;
  const date = new Date(value);
  return Number.isNaN(date.getTime()) ? value.match(/\b\d{4}\b/)?.[0] ?? value : String(date.getFullYear());
};
---

<BaseLayout {...seo.reading} schemaType="CollectionPage">
  <section class="page-hero books-hero">
    <p class="eyebrow">/ Reading</p>
    <h1>Books that shaped my thinking.</h1>
    <p>
      The ideas, mental models, and perspectives that continue to influence how I approach
      startups, AI, strategy, technology, and human behavior.
    </p>
  </section>

  <section class="book-list" aria-label="Reading list">
    {books.map((book) => (
      <article class="book-row">
        <div class="book-row-copy">
          <div class="book-row-heading">
            <h2>{book.title}</h2>
            <p>{book.author}</p>
            <time datetime={book.year === "n.d." ? undefined : book.year}>{publicationYear(book.year)}</time>
          </div>
          <p class="book-excerpt">{book.excerpt}</p>
        </div>
        <a href={book.href} target="_blank" rel="noreferrer">Read</a>
      </article>
    ))}
  </section>
  <BackToTop />
</BaseLayout>
