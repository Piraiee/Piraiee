---
import BaseLayout from "../layouts/BaseLayout.astro";
import DealCard from "../components/DealCard.astro";
import ContactForm from "../components/ContactForm.astro";
import { deals } from "../data/deals";
---

<BaseLayout title="Deals" description="Curated startup and operator deals from Ahmad Piraiee.">
  <section class="page-hero compact">
    <p class="eyebrow">Deals</p>
    <h1>Curated offers for founders, operators, and startup teams.</h1>
  </section>
  <div class="deal-grid">
    {deals.map((deal) => <DealCard deal={deal} />)}
  </div>
  <section class="contact-panel">
    <div>
      <p class="eyebrow">Need access?</p>
      <h2>Ask for the right introduction.</h2>
      <p>Some partner offers need a manual intro or eligibility check.</p>
    </div>
    <ContactForm />
  </section>
</BaseLayout>
