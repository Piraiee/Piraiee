---
import type { Deal } from "../data/deals";

type Props = {
  deal: Deal;
};

const { deal } = Astro.props;
---

<article class="deal-card">
  <p class="eyebrow">{deal.category}</p>
  <h3>{deal.name}</h3>
  <p class="lead-small">{deal.summary}</p>
  <p>{deal.details} <a class="text-link inline-link" href={`/deals/${deal.slug}/`}>Explore deal</a></p>
</article>
