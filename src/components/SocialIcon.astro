---
type Props = {
  label: string;
  href: string;
};

const { label, href } = Astro.props;
const key = label.toLowerCase();
---

<a class="social-icon" href={href} rel="me noopener noreferrer" aria-label={label}>
  {
    key === "instagram" ? (
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <rect x="4" y="4" width="16" height="16" rx="5" />
        <circle cx="12" cy="12" r="3.4" />
        <circle cx="16.8" cy="7.2" r="0.7" />
      </svg>
    ) : key === "linkedin" ? (
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path class="icon-fill" d="M5.2 9.1h3.1v9.7H5.2z" />
        <path class="icon-fill" d="M6.8 5.2a1.7 1.7 0 1 1 0 3.4 1.7 1.7 0 0 1 0-3.4z" />
        <path class="icon-fill" d="M10.8 9.1h3v1.3c.5-.8 1.5-1.5 3-1.5 2.3 0 3.9 1.5 3.9 4.6v5.3h-3.1v-4.9c0-1.4-.5-2.3-1.8-2.3-1.1 0-1.8.8-1.8 2.3v4.9h-3.2z" />
      </svg>
    ) : key === "x" ? (
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path class="icon-fill" d="M5.5 5h3.8l9.2 14h-3.8z" />
        <path d="M18.4 5.2 5.8 18.8" />
      </svg>
    ) : key === "threads" ? (
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M12 3.5c5 0 7.7 3 7.7 8.6 0 5.2-2.8 8.4-7.5 8.4-4.8 0-7.8-3.2-7.8-8.4 0-5.6 2.7-8.6 7.6-8.6z" />
        <path d="M9.2 8.8c.7-1 1.7-1.5 3-1.5 2.2 0 3.4 1.3 3.6 3.8" />
        <path d="M15.8 11.2c-1-.5-2.1-.7-3.5-.6-2.2.1-3.3 1.1-3.2 2.5.1 1.3 1.3 2 2.8 1.9 1.8-.1 3.1-1.1 3.4-3.6" />
      </svg>
    ) : key === "goodreads" ? (
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path class="icon-fill" d="M16.2 7.5v8.7c0 3-1.6 4.6-4.5 4.6-2.3 0-3.9-1-4.2-2.8h2.3c.3.8 1 1.1 2 1.1 1.5 0 2.2-.8 2.2-2.4v-1c-.6.8-1.5 1.2-2.8 1.2-2.5 0-4.2-1.9-4.2-4.8s1.7-4.8 4.2-4.8c1.3 0 2.3.5 2.9 1.4V7.5z" />
        <path class="icon-cutout" d="M11.7 9.2c-1.4 0-2.3 1.1-2.3 2.9s.9 2.9 2.3 2.9 2.4-1.1 2.4-2.9-.9-2.9-2.4-2.9z" />
      </svg>
    ) : (
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M9.5 8h-2a4 4 0 0 0 0 8h2" />
        <path d="M14.5 8h2a4 4 0 0 1 0 8h-2" />
        <path d="M8.5 12h7" />
      </svg>
    )
  }
</a>
