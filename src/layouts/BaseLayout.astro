---
import { navItems, site } from "../data/site";
import SocialIcon from "../components/SocialIcon.astro";
import "@fontsource/inter/400.css";
import "@fontsource/inter/600.css";
import "@fontsource/inter/700.css";
import "@fontsource/inter/800.css";
import "@fontsource/manrope/400.css";
import "@fontsource/manrope/600.css";
import "@fontsource/manrope/700.css";
import "@fontsource/manrope/800.css";
import "../styles/global.css";

type Props = {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  robots?: string;
  schemaType?: "WebPage" | "ProfilePage" | "CollectionPage" | "BlogPosting";
  publishedTime?: string;
  modifiedTime?: string;
  section?: string;
};

const {
  title = site.name,
  description = site.description,
  image = site.heroImage,
  imageAlt = `${title} on ${site.domain}`,
  robots = "index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1",
  schemaType = "WebPage",
  publishedTime,
  modifiedTime,
  section
} = Astro.props;

const pageTitle = title === site.name ? `${site.name} | ${site.domain}` : `${title} | ${site.name}`;
const canonical = new URL(Astro.url.pathname, site.url).toString();
const absoluteImage = new URL(image, site.url).toString();
const pathname = Astro.url.pathname;

const personId = `${site.url}/#person`;
const websiteId = `${site.url}/#website`;
const webpageId = `${canonical}#webpage`;
const primaryImageId = `${canonical}#primaryimage`;
const person = {
  "@type": "Person",
  "@id": personId,
  name: site.name,
  url: site.url,
  image: new URL("/assets/brand/ahmad-piraiee-portrait-new.png", site.url).toString(),
  sameAs: site.socials.map((item) => item.href),
  jobTitle: "Strategist, venture builder, and execution partner"
};
const website = {
  "@type": "WebSite",
  "@id": websiteId,
  url: site.url,
  name: site.domain,
  description: site.description,
  publisher: { "@id": personId },
  inLanguage: "en"
};
const primaryImage = {
  "@type": "ImageObject",
  "@id": primaryImageId,
  url: absoluteImage,
  contentUrl: absoluteImage,
  width: 1200,
  height: 630,
  caption: imageAlt
};
const webPage = {
  "@type": schemaType === "BlogPosting" ? "WebPage" : schemaType,
  "@id": webpageId,
  url: canonical,
  name: pageTitle,
  headline: title,
  description,
  image: { "@id": primaryImageId },
  primaryImageOfPage: { "@id": primaryImageId },
  inLanguage: "en",
  isPartOf: { "@id": websiteId },
  author: { "@id": personId },
  ...(schemaType === "ProfilePage" ? { mainEntity: { "@id": personId } } : {})
};
const article = schemaType === "BlogPosting" ? {
  "@type": "BlogPosting",
  "@id": `${canonical}#article`,
  url: canonical,
  headline: title,
  description,
  image: { "@id": primaryImageId },
  datePublished: publishedTime,
  dateModified: modifiedTime || publishedTime,
  articleSection: section,
  inLanguage: "en",
  mainEntityOfPage: { "@id": webpageId },
  author: { "@id": personId },
  publisher: { "@id": personId }
} : null;
const graph: unknown[] = [website, person, primaryImage, webPage];
if (article) graph.push(article);
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": graph
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="author" content={site.name} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0B0D10" />
    <meta property="og:type" content={schemaType === "BlogPosting" ? "article" : "website"} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content={site.domain} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={absoluteImage} />
    <meta property="og:image:secure_url" content={absoluteImage} />
    <meta property="og:image:type" content={absoluteImage.endsWith(".jpg") || absoluteImage.endsWith(".jpeg") ? "image/jpeg" : "image/png"} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={imageAlt} />
    {schemaType === "BlogPosting" && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {schemaType === "BlogPosting" && (modifiedTime || publishedTime) && <meta property="article:modified_time" content={modifiedTime || publishedTime} />}
    {schemaType === "BlogPosting" && section && <meta property="article:section" content={section} />}
    {schemaType === "BlogPosting" && <meta property="article:author" content={site.url} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteImage} />
    <meta name="twitter:image:alt" content={imageAlt} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header" data-header>
      <div class="nav-shell">
        <div class="brand wordmark header-wordmark" aria-label="piraiee.com">
          <span class="wordmark-slash" aria-hidden="true">/</span><span class="wordmark-type" aria-hidden="true">piraiee.com</span>
        </div>
        <button class="menu-toggle" type="button" aria-label="Toggle navigation" aria-expanded="false" data-menu-toggle>
          <span aria-hidden="true"></span>
        </button>
        <nav aria-label="Main navigation" data-nav>
          {navItems.map((item) => {
            const active = item.href === "/" ? pathname === "/" : pathname.startsWith(item.href);
            return <a href={item.href} aria-current={active ? "page" : undefined}>{item.label}</a>;
          })}
        </nav>
        <div class="nav-actions">
          <a class="button nav-button" href="/#contact">Contact ↗</a>
        </div>
        <div class="mobile-menu-socials" aria-label="Social links">
          {site.socials.map((item) => <SocialIcon label={item.label} href={item.href} />)}
        </div>
      </div>
    </header>
    <main id="main">
      <slot />
    </main>
    <dialog class="success-modal" data-form-success-modal aria-labelledby="form-success-title">
      <div class="success-modal-card">
        <p class="eyebrow" data-form-success-eyebrow>Request received</p>
        <h2 id="form-success-title">I received your data and will get back to you soon.</h2>
        <button class="button" type="button" data-form-success-close>Close</button>
      </div>
    </dialog>
    <footer class="site-footer">
      <div class="footer-line">
        <p>Startups, capital, communities, and strategic opportunities.</p>
        <div class="footer-socials">
          {site.socials.map((item) => <SocialIcon label={item.label} href={item.href} />)}
        </div>
      </div>
      <p class="copyright">©1998-2026 piraiee.com · all rights reserved</p>
    </footer>
    <aside class="cookie-consent" data-cookie-consent hidden aria-label="Cookie preferences">
      <div>
        <p>By using piraiee.com, you agree to our use of cookies. We use cookies to provide you with a great experience and help our website run effectively.</p>
        <a href="/privacy/">Cookies and data privacy</a>
      </div>
      <div class="cookie-actions">
        <button class="button secondary" type="button" data-cookie-essential>Essential only</button>
        <button class="button" type="button" data-cookie-accept>Accept</button>
      </div>
    </aside>
    <script>
      const header = document.querySelector("[data-header]");
      const toggle = document.querySelector("[data-menu-toggle]");
      const syncHeader = () => header?.classList.toggle("is-scrolled", window.scrollY > 16);
      syncHeader();
      window.addEventListener("scroll", syncHeader, { passive: true });
      const setMenu = (open: boolean) => {
        header?.classList.toggle("menu-open", open);
        document.documentElement.classList.toggle("menu-is-open", open);
        toggle?.setAttribute("aria-expanded", String(open));
      };
      toggle?.addEventListener("click", () => {
        setMenu(!header?.classList.contains("menu-open"));
      });
      header?.querySelectorAll("nav a, .nav-actions a").forEach((link) => {
        link.addEventListener("click", () => setMenu(false));
      });
      window.addEventListener("keydown", (event) => {
        if (event.key === "Escape") setMenu(false);
      });

      document.querySelectorAll(".accordion-list").forEach((accordion) => {
        const items = Array.from(accordion.querySelectorAll("details"));
        items.forEach((item) => item.addEventListener("toggle", () => {
          if (item.open) items.forEach((other) => {
            if (other !== item) other.open = false;
          });
        }));
      });

      const formSuccessModal = document.querySelector("[data-form-success-modal]");
      const formSuccessCloseButton = document.querySelector("[data-form-success-close]");
      const formSuccessEyebrow = document.querySelector<HTMLElement>("[data-form-success-eyebrow]");
      const syncFormSuccessModalLock = () => {
        document.documentElement.classList.toggle("modal-open", Boolean(document.querySelector("dialog[open]")));
      };
      const closeFormSuccessModal = () => {
        if (formSuccessModal instanceof HTMLDialogElement) formSuccessModal.close();
      };
      const openFormSuccessModal = (eyebrow = "Request received") => {
        if (formSuccessEyebrow) formSuccessEyebrow.textContent = eyebrow;
        if (formSuccessModal instanceof HTMLDialogElement) {
          formSuccessModal.showModal();
          document.documentElement.classList.add("modal-open");
        }
      };
      formSuccessCloseButton?.addEventListener("click", closeFormSuccessModal);
      formSuccessModal?.addEventListener("close", () => requestAnimationFrame(syncFormSuccessModalLock));
      formSuccessModal?.addEventListener("click", (event) => {
        if (event.target === formSuccessModal) closeFormSuccessModal();
      });
      window.addEventListener("piraiee:form-success", (event) => {
        const detail = event instanceof CustomEvent ? event.detail as { eyebrow?: string } : {};
        openFormSuccessModal(detail.eyebrow || "Request received");
      });

      const consentKey = "piraiee-cookie-consent-v1";
      const consentBanner = document.querySelector("[data-cookie-consent]");
      const analyticsWindow = window as typeof window & {
        dataLayer: unknown[][];
        gtag: (...args: unknown[]) => void;
      };
      const loadAnalytics = () => {
        if (document.querySelector("script[data-piraiee-analytics]")) return;
        analyticsWindow.dataLayer = analyticsWindow.dataLayer || [];
        analyticsWindow.gtag = (...args: unknown[]) => { analyticsWindow.dataLayer.push(args); };
        analyticsWindow.gtag("js", new Date());
        analyticsWindow.gtag("config", "G-KTW8ESEEMM", { anonymize_ip: true });
        const script = document.createElement("script");
        script.async = true;
        script.src = "https://www.googletagmanager.com/gtag/js?id=G-KTW8ESEEMM";
        script.dataset.piraieeAnalytics = "true";
        document.head.appendChild(script);
      };
      const saveConsent = (analytics: boolean) => {
        localStorage.setItem(consentKey, JSON.stringify({ analytics, savedAt: new Date().toISOString() }));
        consentBanner?.setAttribute("hidden", "");
        if (analytics) loadAnalytics();
      };
      let savedConsent: { analytics?: boolean } | null = null;
      try { savedConsent = JSON.parse(localStorage.getItem(consentKey) || "null"); } catch {}
      if (savedConsent?.analytics === true) loadAnalytics();
      if (!savedConsent) consentBanner?.removeAttribute("hidden");
      document.querySelector("[data-cookie-essential]")?.addEventListener("click", () => saveConsent(false));
      document.querySelector("[data-cookie-accept]")?.addEventListener("click", () => saveConsent(true));
      document.querySelectorAll("[data-cookie-reset]").forEach((button) => button.addEventListener("click", () => {
        localStorage.removeItem(consentKey);
        location.reload();
      }));
    </script>
  </body>
</html>
